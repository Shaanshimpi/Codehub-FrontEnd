### 14.2 Topic - Multilevel Inheritance (Parent -> Child -> GrandChild)

- **Exclusions (do not teach or mention in this topic)**
  - Do **not** introduce or reference: multiple inheritance; `protected` (separate topic later); virtual functions/polymorphism; constructors chaining; templates; `new/delete`.
  - Use only: `class A`, `class B : public A`, `class C : public B`, and reuse across 3 levels.

- **Core concepts**
  - Multilevel inheritance means: a class inherits from a class that already inherits from another.
  - GrandChild gets features from both Parent and Child.

- **Example snippets**

```cpp
// 1. DemoParent -> DemoChild -> DemoGrandChild
#include <iostream>
using namespace std;

class DemoParent {
public:
    void msgParent() {
        cout << "Parent\n";
    }
};

class DemoChild : public DemoParent {
public:
    void msgChild() {
        cout << "Child\n";
    }
};

class DemoGrandChild : public DemoChild {
public:
    void msgGrandChild() {
        cout << "GrandChild\n";
    }
};

int main() {
    DemoGrandChild g;
    g.msgParent();
    g.msgChild();
    g.msgGrandChild();
    return 0;
}
```

```cpp
// 2. Application: User -> Student -> TopperStudent (multiple properties)
#include <iostream>
#include <string>
using namespace std;

class User {
public:
    string name;
    int age;
    string city;

    void setUser(string n, int a, string c) {
        name = n;
        age = a;
        city = c;
    }

    void displayUser() {
        cout << "Name: " << name << ", Age: " << age << ", City: " << city << "\n";
    }
};

class Student : public User {
public:
    int rollNo;
    float marks;

    void setStudent(int r, float m) {
        rollNo = r;
        marks = m;
    }

    void displayStudent() {
        displayUser();
        cout << "RollNo: " << rollNo << ", Marks: " << marks << "\n";
    }
};

class TopperStudent : public Student {
public:
    int rank;
    string scholarship;

    void setTopper(int r, string s) {
        rank = r;
        scholarship = s;
    }

    void displayTopper() {
        displayStudent();
        cout << "Rank: " << rank << ", Scholarship: " << scholarship << "\n";
    }
};

int main() {
    TopperStudent ts;
    ts.setUser("Aman", 18, "Mumbai");
    ts.setStudent(5, 98.5f);
    ts.setTopper(1, "Merit");
    ts.displayTopper();
    return 0;
}
```

```cpp
// 3. Application: Vehicle -> Car -> SportsCar (multiple properties)
#include <iostream>
#include <string>
using namespace std;

class Vehicle {
public:
    string brand;
    int wheels;

    void setVehicle(string b, int w) {
        brand = b;
        wheels = w;
    }

    void displayVehicle() {
        cout << "Brand: " << brand << ", Wheels: " << wheels << "\n";
    }
};

class Car : public Vehicle {
public:
    int doors;
    string fuel;

    void setCar(int d, string f) {
        doors = d;
        fuel = f;
    }

    void displayCar() {
        displayVehicle();
        cout << "Doors: " << doors << ", Fuel: " << fuel << "\n";
    }
};

class SportsCar : public Car {
public:
    int topSpeed;
    float zeroToHundred;

    void setSports(int s, float z) {
        topSpeed = s;
        zeroToHundred = z;
    }

