    cout << "Car 2: " << car2.brand << " " << car2.model << ", Year: " << car2.year << ", Price: " << car2.price << "\n";
    return 0;
}
```

```cpp
// 6. Array of cars
#include <iostream>
#include <string>
using namespace std;

struct Car {
    string brand;
