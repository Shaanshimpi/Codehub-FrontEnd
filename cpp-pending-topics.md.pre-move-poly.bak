## 6. Functions - Tutorial specs for AI (C++)

#### 6.1 Topic - Introduction to Functions (void, no parameters)

- **Exclusions (do not teach or mention in this topic)**
  - Do **not** introduce or reference: function parameters; return types other than `void`; returning values; recursion; arrays; strings (beyond `cout/cin`); pointers; classes/objects; templates; references.
  - Use only: `void functionName()` with empty parentheses, calling from `main`, and basic control flow/loops inside the function body. Any input must be read inside the function (not passed as parameters).

```cpp
// 1. Function defined but not called
#include <iostream>
using namespace std;

void hello() {
    cout << "Hello Codehub\n";
}

int main() {
    // hello(); // not called
    return 0;
}
```

```cpp
// 2. Calling a simple void function once
#include <iostream>
using namespace std;

void hello() {
    cout << "Hello Codehub\n";
}

int main() {
    hello();
    return 0;
}
```

```cpp
// 3. Reusing the same function multiple times
#include <iostream>
using namespace std;

void hello() {
    cout << "Hello Codehub\n";
}

int main() {
    hello();
    hello();
    hello();
    hello();
    return 0;
}
```

```cpp
// 4. Changing function implementation once, all calls updated
#include <iostream>
using namespace std;

void hello() {
    cout << "Welcome to Codehub!\n";
}

int main() {
    hello();
    hello();
    hello();
    hello();
    return 0;
}
```

```cpp
// 5. Function to check voting eligibility (no parameters)
#include <iostream>
using namespace std;

void checkVoting() {
    int age;
    cout << "Enter your age: ";
    cin >> age;

    if (age >= 18) {
        cout << "You are eligible to vote.\n";
    } else {
        cout << "You are not eligible to vote.\n";
    }
}

int main() {
    checkVoting();
    return 0;
}
```

```cpp
// 6. Function to print numbers from 1 to 100 (no parameters)
#include <iostream>
using namespace std;

void printOneToHundred() {
    for (int i = 1; i <= 100; i++) {
        cout << i << " ";
    }
    cout << "\n";
}

int main() {
    printOneToHundred();
    return 0;
}
```

#### 6.2 Topic - Functions with Parameters (no return yet)

- **Exclusions (do not teach or mention in this topic)**
  - Do **not** introduce or reference: return statements returning a value; non-void return types; recursion; passing arrays; passing strings; pointers; references; function overloading; default parameters.
  - Use only: `void func(int a, int b)` style parameters, passing arguments, and printing results inside the function.

```cpp
// 2. Function with two parameters: print sum
#include <iostream>
using namespace std;

void printSum(int a, int b) {
    cout << "Sum = " << (a + b) << "\n";
}

int main() {
    printSum(3, 5);
    return 0;
}
```

```cpp
// 3. Function with one parameter: print the value
#include <iostream>
using namespace std;

void printValue(int x) {
    cout << "Value = " << x << "\n";
}

int main() {
    printValue(10);
    printValue(25);
    return 0;
}
```

```cpp
// 4. Function with one parameter: print square
#include <iostream>
using namespace std;

void printSquare(int x) {
    cout << "Square of " << x << " = " << (x * x) << "\n";
}

int main() {
    printSquare(4);
    printSquare(7);
    return 0;
}
```

```cpp
// 5. Multiple void functions in one program (no return values)
#include <iostream>
using namespace std;

void printSquare(int x) {
    cout << "Square: " << (x * x) << "\n";
}

void printAdd(int a, int b) {
    cout << "Add: " << (a + b) << "\n";
}

void printSub(int a, int b) {
    cout << "Sub: " << (a - b) << "\n";
}

void printMul(int a, int b) {
    cout << "Mul: " << (a * b) << "\n";
}

int main() {
    printSquare(5);
    printAdd(10, 3);
    printSub(10, 3);
    printMul(4, 6);
    return 0;
}
```

#### 6.3 Topic - Functions with Return Values (using function output)

- **Exclusions (do not teach or mention in this topic)**
  - Do **not** introduce or reference: recursion; passing arrays; passing strings; pointers; references; templates.
  - Use only: parameters (ints), non-void return types (e.g. `int`, `long long`), and using return values in `main`.

```cpp
// 3. Function that returns square
#include <iostream>
using namespace std;

int square(int x) {
    return x * x;
}

int main() {
    cout << square(7) << "\n";
    return 0;
}
```

```cpp
// 4. Function that returns the same value
#include <iostream>
using namespace std;

int getValue(int x) {
    return x;
}

int main() {
    int num = getValue(42);
    cout << "Returned value = " << num << "\n";
    return 0;
}
```

```cpp
// 5. Function with two parameters: return sum (used in expression)
#include <iostream>
using namespace std;

int add(int a, int b) {
    return a + b;
}

int main() {
    int x = 5, y = 7;
    int s = add(x, y);
    cout << "Sum = " << s << "\n";
    cout << "Sum + 10 = " << (add(x, y) + 10) << "\n";
    return 0;
}
```

```cpp
// 6. Multiple returning functions in one program
#include <iostream>
using namespace std;

int square(int x) {
  return x * x; 
}
int add(int a, int b) {
  return a + b; 
}
int sub(int a, int b) {
  return a - b; 
}
int mul(int a, int b) {
  return a * b; 
}

int main() {
    int x = 5, y = 3;
    cout << "square(" << x << ") = " << square(x) << "\n";
    cout << "add(" << x << ", " << y << ") = " << add(x, y) << "\n";
    cout << "sub(" << x << ", " << y << ") = " << sub(x, y) << "\n";
    cout << "mul(" << x << ", " << y << ") = " << mul(x, y) << "\n";
    return 0;
}
```

#### 6.4 Topic - Predicate and Helper Functions

- **Exclusions (do not teach or mention in this topic)**
  - Do **not** introduce or reference: recursion; passing arrays; passing strings; pointers; references; templates.
  - Use only: functions with parameters and return values returning 0/1 (or `bool` only if explicitly introduced in this topic) and helpers like `max2`.

```cpp
// 4. Predicate function: isEven
#include <iostream>
using namespace std;

int isEven(int x) {
    return x % 2 == 0;
}

int main() {
    int n;
    cout << "Enter n: ";
    cin >> n;
    if (isEven(n)) {
        cout << "Even\n";
    } else {
        cout << "Odd\n";
    }
    return 0;
}
```

```cpp
// 5. Helper function: max2
#include <iostream>
using namespace std;

int max2(int a, int b) {
    if (a > b) {
        return a;
    } else {
        return b;
    }
}

int main() {
    int x = 10, y = 20;
    cout << "Max = " << max2(x, y) << "\n";
    return 0;
}
```

```cpp
// 6. Using isEven in a loop: count evens from 1 to n
#include <iostream>
using namespace std;

int isEven(int x) {
    return x % 2 == 0;
}

int main() {
    int n;
    cout << "Enter n: ";
    cin >> n;

    int count = 0;
    for (int i = 1; i <= n; i++) {
        if (isEven(i)) {
            count++;
        }
    }

    cout << "There are " << count << " even numbers from 1 to " << n << "\n";
    return 0;
}
```

