### 14.3 Topic - Multiple Inheritance (one child inherits from two parents)

- **Exclusions (do not teach or mention in this topic)**
  - Do **not** introduce or reference: diamond problem; virtual inheritance; `protected` (separate topic later); polymorphism; templates; `new/delete`.
  - Use only: simple two-parent multiple inheritance with non-conflicting member names.

- **Core concepts**
  - Multiple inheritance means: `class Child : public Parent1, public Parent2 { ... };`
  - Child can use members from both parents.
  - Keep examples simple and avoid name conflicts at this stage.

- **Example snippets**

```cpp
// 1. Demo: Child inherits from two parents
#include <iostream>
using namespace std;

class DemoA {
public:
    void msgA() {
        cout << "From A\n";
    }
};

class DemoB {
public:
    void msgB() {
        cout << "From B\n";
    }
};

class DemoChild : public DemoA, public DemoB {
public:
    void msgChild() {
        cout << "From Child\n";
    }
};

int main() {
    DemoChild d;
    d.msgA();
    d.msgB();
    d.msgChild();
    return 0;
}
```

```cpp
// 2. Practical example: PersonInfo + AcademicInfo -> StudentProfile
#include <iostream>
#include <string>
using namespace std;

class PersonInfo {
public:
    string name;
    int age;
    string city;

    void setPerson(string n, int a, string c) {
        name = n;
        age = a;
        city = c;
    }

    void displayPerson() {
        cout << "Name: " << name << ", Age: " << age << ", City: " << city << "\n";
    }
};

class AcademicInfo {
public:
    int rollNo;
    float marks;
    string course;

    void setAcademic(int r, float m, string c) {
        rollNo = r;
        marks = m;
        course = c;
    }

    void displayAcademic() {
        cout << "RollNo: " << rollNo << ", Marks: " << marks << ", Course: " << course << "\n";
    }
};

class StudentProfile : public PersonInfo, public AcademicInfo {
public:
    void displayProfile() {
        displayPerson();
        displayAcademic();
    }
};

int main() {
    StudentProfile sp;
    sp.setPerson("Neha", 19, "Jaipur");
    sp.setAcademic(12, 91.5f, "C++");
    sp.displayProfile();
    return 0;
}
```

```cpp
// 3. Another example: VehicleInfo + PricingInfo -> CarDetails
#include <iostream>
#include <string>
using namespace std;

class VehicleInfo {
public:
    string brand;
    int year;
    int wheels;

    void setVehicle(string b, int y, int w) {
        brand = b;
        year = y;
        wheels = w;
    }

    void displayVehicle() {
        cout << "Brand: " << brand << ", Year: " << year << ", Wheels: " << wheels << "\n";
    }
};

class PricingInfo {
public:
    float price;
    float taxPercent;

    void setPrice(float p, float tax) {
        price = p;
        taxPercent = tax;
    }

    float totalPrice() {
        return price + (price * taxPercent / 100.0f);
    }

    void displayPrice() {
        cout << "Price: " << price << ", Tax: " << taxPercent << "%, Total: " << totalPrice() << "\n";
    }
};

class CarDetails : public VehicleInfo, public PricingInfo {
public:
    void displayAll() {
        displayVehicle();
        displayPrice();
    }
};

int main() {
    CarDetails c;
    c.setVehicle("Toyota", 2020, 4);
    c.setPrice(15000.0f, 12.0f);
    c.displayAll();
    return 0;
}
```

